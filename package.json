{
  "name": "disputable.io",
  "version": "1.0.0",
  "description": "disputable.io - disputes in, disputes out.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --experimental-vm-modules tests/run-all.js",
    "test:coverage": "npx c8 --reporter=text --reporter=lcov node --experimental-vm-modules tests/run-all.js",
    "test:check": "npx c8 check-coverage --lines 85 --functions 85 --branches 80 node --experimental-vm-modules tests/run-all.js",
    "serve": "npx serve . -p 3000"
  },
  "devDependencies": {
    "c8": "^10.1.2"
  }
}
